<div class="container">
  <h3 class="text-center">Danh Sách Nhân Viên</h3>
  <div class="table-container table-responsive">
    <br />
    <table class="table table-hover stan-custom-table">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Tên</th>
          <th>Địa chỉ</th>
          <th>Số điện thoại</th>
          <th>Chức vụ</th>
          <th colspan="3">Thao tác</th>
        </tr>
      </thead>

      <% if(u.length> 0){ %> <% for(var i=0; i < u.length; i++){ %>
          <tr>
            <td class="sticky-col first-col"><%- u[i].id %></td>

            <td class="sticky-col second-col"><%- u[i].firstName %></td>

            <td><%- u[i].address %></td>

            <td><%- u[i].phonenumber %></td>

            <td><%- u[i].rolename %></td>

            <td>
              <% if(u[i].email){ %>
                <a href="#divUD<%- u[i].id %>" class="active-popup">
                  <i class="bx bxs-edit-alt"></i>
                </a>
                <% } %>
                  <div class="UD_overplay" id="divUD<%- u[i].id %>">
                    <div class="nv_wrapper bg-white"
                      style="max-width: 600px; padding: 25px 30px; border-radius: 12px; position: relative; height: auto !important; margin: auto;">
                      <a href="#" class="close text-dark text-decoration-none fs-3 position-absolute"
                        style="top: 10px; right: 20px;">&times;</a>
                      <h3 class="text-center mb-4 fw-bold text-uppercase" style="color: #333; font-size: 1.5rem;">Sửa
                        Thông Tin</h3>

                      <form class="form-edit-nhan-vien d-flex flex-column"
                        action="/suanhanvien?user_id=<%- u[i].user_id %>" method="POST" data-id="<%- u[i].user_id %>">
                        <div class="row mb-3">
                          <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label text-muted small fw-bold mb-1">Họ</label>
                            <input name="lastName" type="text" class="form-control shadow-sm border-0 bg-light"
                              value="<%- u[i].lastName %>" />
                          </div>
                          <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold mb-1">Tên</label>
                            <input name="firstName" type="text" class="form-control shadow-sm border-0 bg-light"
                              value="<%- u[i].firstName %>" required />
                          </div>
                        </div>

                        <div class="row mb-3">
                          <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label text-muted small fw-bold mb-1">Email</label>
                            <input name="email" type="email" class="form-control shadow-sm border-0 bg-light"
                              value="<%- u[i].email %>" />
                          </div>
                          <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold mb-1">Số điện thoại</label>
                            <input name="phonenumber" type="text" class="form-control shadow-sm border-0 bg-light"
                              value="<%- u[i].phonenumber %>" />
                          </div>
                        </div>

                        <div class="row mb-3">
                          <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label text-muted small fw-bold mb-1">Chức vụ</label>
                            <select class="form-select shadow-sm border-0 bg-light" name="u_d_id">
                              <option value="<%- u[i].d_id %>" selected><%- u[i].rolename %></option>
                            </select>
                          </div>
                          <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold mb-1">Giới tính</label>
                            <select name="gender" class="form-select shadow-sm border-0 bg-light">
                              <option value="1" <%- u[i].gender==1 ? 'selected' : '' %>>Nam</option>
                              <option value="0" <%- u[i].gender==0 ? 'selected' : '' %>>Nữ</option>
                            </select>
                          </div>
                        </div>

                        <div class="row mb-4">
                          <div class="col-12">
                            <label class="form-label text-muted small fw-bold mb-1">Địa chỉ</label>
                            <textarea name="address" class="form-control shadow-sm border-0 bg-light"
                              rows="2"><%- u[i].address %></textarea>
                          </div>
                        </div>

                        <button class="btn btn-primary w-100 py-2 fw-bold shadow-sm rounded-3 mt-2" type="submit"
                          style="font-size: 1.1rem; letter-spacing: 0.5px;">
                          CẬP NHẬT
                        </button>
                      </form>
                    </div>
                  </div>
            </td>

            <td>
              <% if(u[i].rolecode !='super-admin' ){ %>
                <a href="#divDel<%- u[i].id %>" class="active-popup"><i class="bx bx-user-minus"></i></a>
                <% } %>
                  <div class="UD_overplay" id="divDel<%- u[i].id %>">
                    <div class="nv_wrapper bg-white"
                      style="max-width: 450px; padding: 30px; border-radius: 12px; position: relative; height: auto !important; margin: auto; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                      <a href="#" class="close text-dark text-decoration-none fs-3 position-absolute"
                        style="top: 10px; right: 20px;">&times;</a>
                      <div class="text-center mb-4">
                        <i class="bx bx-trash text-danger" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold text-uppercase mt-2" style="color: #333; font-size: 1.4rem;">Xác Nhận Xóa
                        </h3>
                        <p class="text-muted small mt-1">Bạn có chắc chắn muốn xóa nhân viên này không?</p>
                      </div>

                      <form class="d-flex flex-column" action="/xoanhanvien" method="POST">
                        <input name="user_id" type="hidden" value="<%- u[i].user_id %>" />

                        <div class="mb-4">
                          <label class="form-label text-muted small fw-bold mb-1">Tên Nhân Viên</label>
                          <input name="firstName" type="text"
                            class="form-control shadow-sm border-0 bg-light text-center fw-bold text-danger"
                            value="<%- u[i].firstName %>" readonly
                            style="font-size: 1.1rem; padding: 10px; pointer-events: none;" />
                        </div>

                        <div class="d-flex justify-content-between gap-2 mt-2">
                          <a href="#" class="btn btn-secondary w-50 py-2 fw-bold shadow-sm rounded-3">HỦY BỎ</a>
                          <button class="btn btn-danger w-50 py-2 fw-bold shadow-sm rounded-3" type="submit"
                            style="letter-spacing: 0.5px;">XÓA NGAY</button>
                        </div>
                      </form>
                    </div>
                  </div>
            </td>
          </tr>
          <% } %>
            <% } else { %>
              <p>Không có nhân viên</p>
              <% } %>
    </table>
  </div>
</div>

<style>
  /* .table-container {
    width: 100%;
    overflow-x: auto;
    max-width: 100%;
  } */

  .stan-custom-table {
    width: 100%;
    border-collapse: collapse;
  }

  .stan-custom-table th,
  .stan-custom-table td {
    padding: 10px;
    border: 1px solid #ddd;
    white-space: nowrap;
    background-color: white;
    /* Để tránh bị trong suốt khi cuộn */
  }

  /* Cố định 3 cột đầu tiên */
  .sticky-col {
    position: sticky;
    z-index: 2;
    background-color: #f8f9fa;
  }

  .first-col {
    left: 0;
    min-width: 50px;
    background-color: #e9ecef;
    box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
    border-right: 1px solid #ccc;
  }

  .second-col {
    left: 50px;
    min-width: 100px;
    background-color: #e9ecef;
    border-right: 1px solid #ccc;
  }

  .third-col {
    left: 150px;
    min-width: 150px;
    background-color: #e9ecef;
    border-right: 1px solid #ccc;
  }

  thead .sticky-col {
    top: 0;
    z-index: 3;
    background-color: #343a40;
    color: white;
  }

  .UD_overplay {
    z-index: 9999 !important;
  }
</style>

<script>
  $(document).ready(function () {
    $(".form-edit-nhan-vien").submit(function (event) {
      event.preventDefault(); // Ngăn chặn reload trang

      var checkError = false;
      var formDataCheck = $(this).serializeArray();
      formDataCheck.forEach(function (item) {
        if (item.name == "firstName" && item.value == "") {
          checkError = true;
          alert("Không được bỏ trống tên!");
          return false; // Dừng vòng lặp
        }
      });

      if (checkError) {
        return;
      }

      // Lấy dữ liệu từ form
      var formData = $(this).serialize();

      // Gửi dữ liệu bằng AJAX
      $.ajax({
        url: $(this).attr("action"), // Lấy action từ form
        type: $(this).attr("method"), // Lấy method từ form
        data: formData,
        success: function (response) {
          location.replace("/nhanvien");
        },
        error: function (xhr) {
          try {
            let res = JSON.parse(xhr.responseText);
            alert(res.message);
          } catch (e) {
            console.error(e);
            alert(xhr.responseText || "Có lỗi xảy ra!");
          }
        },
      });
    });
  });
</script>